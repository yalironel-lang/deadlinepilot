generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String       @id @default(cuid())
  name                String?
  email               String       @unique
  passwordHash        String
  onboardingCompleted Boolean      @default(false)
  createdAt           DateTime     @default(now())
  courses             Course[]
  documents           Document[]
  assignments         Assignment[]
  resources           Resource[]
}

model Course {
  id          String       @id @default(cuid())
  userId      String
  name        String
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   Document[]
  assignments Assignment[]
  resources   Resource[]
}

model Assignment {
  id                   String     @id @default(cuid())
  userId               String
  courseId             String
  documentId           String?
  title                String
  description          String?
  dueDate              DateTime
  status               String     @default("not_started")
  riskScore            Float      @default(0)
  extractionConfidence Float?
  reviewed             Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course               Course     @relation(fields: [courseId], references: [id])
  document             Document?  @relation(fields: [documentId], references: [id])
  tasks                Task[]
  resources            Resource[]
}

// A resource belongs to exactly one of: a Course or an Assignment.
// courseId is non-null for course-level resources.
// assignmentId is non-null for assignment-level resources.
// Exactly one must be set — enforced at the API layer.
model Resource {
  id           String      @id @default(cuid())
  courseId     String?     // set for course-level resources; null for assignment-level
  assignmentId String?     // set for assignment-level resources; null for course-level
  userId       String
  type         String      // "file" | "link" | "chat_reference" | "note"
  title        String
  description  String?
  url          String?     // required for link and chat_reference
  body         String?     // required for note
  filename     String?
  storagePath  String?
  mimeType     String?
  fileSize     Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id                   String       @id @default(cuid())
  userId               String
  courseId             String?
  filename             String
  storagePath          String
  extractionStatus     String       @default("pending")
  extractionConfidence Float?
  rawText              String?
  errorMessage         String?
  uploadedAt           DateTime     @default(now())
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course               Course?      @relation(fields: [courseId], references: [id])
  assignments          Assignment[]
}

model Task {
  id               String     @id @default(cuid())
  assignmentId     String
  title            String
  status           String     @default("not_started")
  estimatedMinutes Int?
  orderIndex       Int        @default(0)
  assignment       Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}
